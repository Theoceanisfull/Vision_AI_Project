{
  "data": {
    "data_root": "data/ASLDVS",
    "encoding": "rate",
    "sensor_size": [
      180,
      240
    ],
    "pool_kernel": [
      6,
      8
    ],
    "num_steps": 20,
    "max_tokens": 1024,
    "batch_size": 32,
    "train_ratio": 0.7,
