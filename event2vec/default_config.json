    "lr": 0.0003,
    "weight_decay": 0.0001,
    "optimizer": "adamw",
    "label_smoothing": 0.0,
    "grad_clip": 1.0,
    "max_train_batches": null,
    "max_val_batches": null,
    "max_test_batches": null,
    "log_every": 50,
    "device": "auto",
    "amp": true,
    "amp_dtype": "bfloat16"
  },
  "result": {
    "out_dir": "runs/event2vec",
    "run_name": "rate",
    "save_plots": true,
    "save_checkpoint": true
  }
}
